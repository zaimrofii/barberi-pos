+  "type": "SERVICE",
+  "name": "Haircut Premium",
+  "price": 150000,
+  "stock": 0,
+  "commission_rate": 0.10
+}
+Response (201):
+
+json
+{
+  "id": "uuid",
+  "type": "SERVICE",
+  "name": "Haircut Premium",
+  "price": "150000.00",
+  "stock": 0,
+  "commission_rate": "0.1000",
+  "created_at": "...",
+  "updated_at": "..."
+}
+GET /api/v1/items?type=PRODUCT&page=1&per_page=20
+Response (200):
+
+json
+{
+  "items": [...],
+  "total": 50,
+  "page": 1,
+  "per_page": 20,
+  "total_pages": 3
+}
+Please implement all of the above following the existing DDD patterns in the codebase.

