# 2026-05-04 19:08:32.845593
+You are implementing Repository Interfaces for a Django DDD modular monolith barbershop POS system.
+
+This is STEP 3: Repository Interfaces only. No implementations, no use cases, no views.
+
+---
+
+CONTEXT:
+- Architecture: Domain-Driven Design modular monolith
+- These are ABSTRACT INTERFACES (contracts) that live in the domain layer
+- Concrete implementations come later in infrastructure/database/repositories/
+- Use cases will depend ONLY on these interfaces, never on Django ORM directly
+
+---
+
+FILES TO CREATE:
+
+1. src/modules/catalog/repositories/item_repository.py
+2. src/modules/sales/repositories/transaction_repository.py
+3. src/modules/staff/repositories/barber_repository.py
+4. src/modules/sales/repositories/__init__.py
+5. src/modules/catalog/repositories/__init__.py
+6. src/modules/staff/repositories/__init__.py
+
+---
+
+REQUIREMENTS:
+
+### 1. src/modules/catalog/repositories/item_repository.py
+
+```python
+from abc import ABC, abstractmethod
+from typing import List
+from uuid import UUID
+
+class AbstractItemRepository(ABC):
+
+    @abstractmethod
+    def get_by_ids_for_update(self, item_ids: List[UUID]) -> List:
+        """
+        Fetch items WHERE id IN (item_ids) WITH pessimistic lock (SELECT FOR UPDATE).
+        Must be called inside an active DB transaction.
+        Returns list of item domain objects (or ORM models).
+        """
+        pass
+
+    @abstractmethod
+    def get_by_id(self, item_id: UUID):
+        """
+        Fetch single item by id. No lock.
+        Raises ItemNotFound if not exists.
+        """
+        pass
+
+    @abstractmethod
+    def save(self, item) -> None:
+        """
+        Persist changes to an item (e.g. after stock deduction).
+        """
+        pass
+
+    @abstractmethod
+    def bulk_save(self, items: List) -> None:
+        """
+        Persist multiple items at once (used after stock deduction in checkout).
+        """
+        pass
+```
+
+### 2. src/modules/sales/repositories/transaction_repository.py
+
+```python
+from abc import ABC, abstractmethod
+from uuid import UUID
+
+class AbstractTransactionRepository(ABC):
+
+    @abstractmethod
+    def get_by_local_id(self, local_id: str):
+        """
+        Idempotency check: find existing transaction by local_id.
+        Returns transaction or None if not found.
+        """
+        pass
+
+    @abstractmethod
+    def get_by_id(self, transaction_id: UUID):
+        """
+        Fetch transaction by server-side UUID.
+        Raises TransactionNotFound if not exists.
+        """
+        pass
+
+    @abstractmethod
+    def save(self, transaction) -> None:
+        """
+        Persist a new transaction (INSERT).
+        """
+        pass
+
+    @abstractmethod
+    def save_items(self, transaction_items: list) -> None:
+        """
+        Bulk insert transaction_items (immutable snapshot rows).
+        Use bulk_create for performance.
+        """
+        pass
+
+    @abstractmethod
+    def update_status(self, transaction_id: UUID, status: str, void_reason: str = None) -> None:
+        """
+        Update transaction status to VOIDED.
+        Only valid transition: COMPLETED → VOIDED.
+        """
+        pass
+```
+
+### 3. src/modules/staff/repositories/barber_repository.py
+
+```python
+from abc import ABC, abstractmethod
+from uuid import UUID
+from typing import List
+
+class AbstractBarberRepository(ABC):
+
+    @abstractmethod
+    def get_by_id(self, barber_id: UUID):
+        """
+        Fetch barber by id.
+        Raises BarberNotFound if not exists.
+        """
+        pass
+
+    @abstractmethod
+    def get_all(self) -> List:
+        """
+        Return all active barbers.
+        """
+        pass
+```
+
+---
+
+CUSTOM EXCEPTIONS TO CREATE:
+
+Create src/modules/sales/repositories/exceptions.py:
+- TransactionNotFound(Exception)
+- CannotVoidTransaction(Exception)  ← raised when trying to void a non-COMPLETED transaction
+
+Create src/modules/catalog/repositories/exceptions.py:
+- ItemNotFound(Exception)
+- OutOfStockError(Exception)  ← raised when stock < requested quantity
+
+Create src/modules/staff/repositories/exceptions.py:
+- BarberNotFound(Exception)
+
+---
+
+VERIFICATION:
+After creating all files, run:
+
+```python
+python manage.py shell -c "
+from modules.catalog.repositories.item_repository import AbstractItemRepository
+from modules.sales.repositories.transaction_repository import AbstractTransactionRepository
+from modules.staff.repositories.barber_repository import AbstractBarberRepository
+from modules.sales.repositories.exceptions import TransactionNotFound, CannotVoidTransaction
+from modules.catalog.repositories.exceptions import ItemNotFound, OutOfStockError
+from modules.staff.repositories.exceptions import BarberNotFound
+import inspect
+
+repos = [AbstractItemRepository, AbstractTransactionRepository, AbstractBarberRepository]
+for r in repos:
+    methods = [m for m in dir(r) if not m.startswith('_')]
+    print(f'✓ {r.__name__}: {methods}')
+
+print('✓ All exceptions importable')
+"
+```
+
+All classes must import without error.
+
+---
+
+DO NOT implement:
+- Any Django ORM queries
+- Any business logic
+- Views, URLs, serializers
+- Concrete repository classes (those go in infrastructure/database/repositories/)
+
+ONLY abstract interfaces + custom exceptions.

